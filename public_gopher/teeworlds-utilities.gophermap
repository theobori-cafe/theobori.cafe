i### More skin configuration	/	tilde.team	70
i	/	tilde.team	70
iHere we are using the SkinFull object to render some in-game	/	tilde.team	70
ifeature like the weapon, hands and emote.	/	tilde.team	70
i	/	tilde.team	70
iimport {	/	tilde.team	70
i  Skin,	/	tilde.team	70
i  Gameskin,	/	tilde.team	70
i  ColorRGB,	/	tilde.team	70
i  Emoticon,	/	tilde.team	70
i  SkinFull,	/	tilde.team	70
i  GameskinPart,	/	tilde.team	70
i  EmoticonPart	/	tilde.team	70
i} from 'teeworlds-utilities';	/	tilde.team	70
i	/	tilde.team	70
iconst fullSkinRenderConfiguration = async () => {	/	tilde.team	70
i  const teedataSunny = new Skin();	/	tilde.team	70
i  await teedataSunny.load('skin.png');	/	tilde.team	70
i	/	tilde.team	70
i  const napolitano = new Gameskin();	/	tilde.team	70
i  await	/	tilde.team	70
inapolitano.load('https://teedata.net/databasev2/gameskins/napolitano/napolitano.png');	/	tilde.team	70
i	/	tilde.team	70
i  const emoticon = new Emoticon();	/	tilde.team	70
i  await	/	tilde.team	70
iemoticon.load('https://teedata.net/databasev2/emoticons/default/default.png');	/	tilde.team	70
i	/	tilde.team	70
i  teedataSunny	/	tilde.team	70
i    .colorTee(	/	tilde.team	70
i      new ColorRGB(255, 255, 255),	/	tilde.team	70
i      new ColorRGB(255, 255, 255),	/	tilde.team	70
i    )	/	tilde.team	70
i    .setOrientation(345);	/	tilde.team	70
i	/	tilde.team	70
i  new SkinFull()	/	tilde.team	70
i    .setSkin(teedataSunny)	/	tilde.team	70
i    .setGameskin(napolitano, GameskinPart.HAMMER)	/	tilde.team	70
i    .setEmoticon(emoticon, EmoticonPart.PART_1_2)	/	tilde.team	70
i    .process()	/	tilde.team	70
i    .saveAs('skin_with_weapon_and_emote.png', true);	/	tilde.team	70
i}	/	tilde.team	70
i	/	tilde.team	70
itry {	/	tilde.team	70
i  fullSkinRenderConfiguration();	/	tilde.team	70
i} catch (err) {	/	tilde.team	70
i  console.error(err);	/	tilde.team	70
i}	/	tilde.team	70
i	/	tilde.team	70
