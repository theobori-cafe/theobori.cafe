i### Merge asset parts	/	tilde.team	70
i	/	tilde.team	70
iHere we are going to merge specific parts from a skin	/	tilde.team	70
i(right) to another (left).	/	tilde.team	70
iAny Teeworlds asset should works.	/	tilde.team	70
i	/	tilde.team	70
i/teedata_skin.png	/	tilde.team	70
i/alien_skin.png	/	tilde.team	70
I/teedata_skin.png	/~nagi/teedata_skin.png	tilde.team	70
I/alien_skin.png	/~nagi/alien_skin.png	tilde.team	70
i	/	tilde.team	70
iimport {	/	tilde.team	70
i  Skin,	/	tilde.team	70
i  SkinPart	/	tilde.team	70
i} from 'teeworlds-utilities';	/	tilde.team	70
i	/	tilde.team	70
iconst mergeTest = async () => {	/	tilde.team	70
i  const teedata = new Skin();	/	tilde.team	70
i  await	/	tilde.team	70
iteedata.load('https://teedata.net/databasev2/skins/teedata/teedata.png');	/	tilde.team	70
i	/	tilde.team	70
i  const sunny = new Skin();	/	tilde.team	70
i  await	/	tilde.team	70
isunny.load('https://teedata.net/databasev2/skins/irradiated%20sunny/irradiated%20sunny.png');	/	tilde.team	70
i	/	tilde.team	70
i  teedata	/	tilde.team	70
i    .copyParts(	/	tilde.team	70
i      sunny,	/	tilde.team	70
i      SkinPart.FOOT,	/	tilde.team	70
i      SkinPart.FOOT_SHADOW,	/	tilde.team	70
i      SkinPart.DEFAULT_EYE,	/	tilde.team	70
i      SkinPart.ANGRY_EYE,	/	tilde.team	70
i      SkinPart.BLINK_EYE,	/	tilde.team	70
i      SkinPart.CROSS_EYE,	/	tilde.team	70
i      SkinPart.HAPPY_EYE,	/	tilde.team	70
i      SkinPart.SCARY_EYE,	/	tilde.team	70
i      SkinPart.HAND_SHADOW,	/	tilde.team	70
i      SkinPart.HAND,	/	tilde.team	70
i    )	/	tilde.team	70
i    .setEyeAssetPart(SkinPart.ANGRY_EYE)	/	tilde.team	70
i    .render()	/	tilde.team	70
i    .saveAs('skin.png')	/	tilde.team	70
i    .saveRenderAs('rendered_skin.png', true)	/	tilde.team	70
i}	/	tilde.team	70
i	/	tilde.team	70
itry {	/	tilde.team	70
i  mergeTest();	/	tilde.team	70
i} catch (err) {	/	tilde.team	70
i  console.error(err);	/	tilde.team	70
i}	/	tilde.team	70
