i## Use case examples	/	tilde.team	70
i### Teeworlds skin rendering	/	tilde.team	70
i	/	tilde.team	70
iRender a Teeworlds 4K skin with default and custom colors.	/	tilde.team	70
i	/	tilde.team	70
iimport {	/	tilde.team	70
i  Skin,	/	tilde.team	70
i  ColorCode,	/	tilde.team	70
i  ColorRGB	/	tilde.team	70
i} from 'teeworlds-utilities';	/	tilde.team	70
i	/	tilde.team	70
iconst renderTest = async () => {	/	tilde.team	70
i  const skin = new Skin();	/	tilde.team	70
i	/	tilde.team	70
i  await	/	tilde.team	70
iskin.load('https://api.skins.tw/database/skins/96AATxN3DEzcGww4QhmduFCsPzaxhZO7Tq6Lh9OI.png');	/	tilde.team	70
i	/	tilde.team	70
i  skin	/	tilde.team	70
i    .render()	/	tilde.team	70
i    .saveRenderAs('default.png', true)	/	tilde.team	70
i    .colorTee(	/	tilde.team	70
i      new ColorCode(6619008),	/	tilde.team	70
i      new ColorRGB(136, 113, 255),	/	tilde.team	70
i    )	/	tilde.team	70
i    .render()	/	tilde.team	70
i    .saveRenderAs('color.png', true);	/	tilde.team	70
i}	/	tilde.team	70
i	/	tilde.team	70
itry {	/	tilde.team	70
i  renderTest();	/	tilde.team	70
i} catch (err) {	/	tilde.team	70
i  console.error(err);	/	tilde.team	70
i}	/	tilde.team	70
