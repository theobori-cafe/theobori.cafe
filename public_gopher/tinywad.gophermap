i### Dumping metadata	/	tilde.team	70
i	/	tilde.team	70
iuse tinywad::error::WadError;	/	tilde.team	70
iuse tinywad::models::operation::WadOp;	/	tilde.team	70
iuse tinywad::wad::Wad;	/	tilde.team	70
i	/	tilde.team	70
ifn main() -> Result<(), WadError> {	/	tilde.team	70
i    let mut src = Wad::new();	/	tilde.team	70
i	/	tilde.team	70
i    src.load_from_file("wads/hexen.wad")?;	/	tilde.team	70
i    src.dump();	/	tilde.team	70
i	/	tilde.team	70
i    Ok(())	/	tilde.team	70
i}	/	tilde.team	70
i	/	tilde.team	70
