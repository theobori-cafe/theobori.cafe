i### Building a PWAD from scratch	/	tilde.team	70
i	/	tilde.team	70
iuse tinywad::error::WadError;	/	tilde.team	70
iuse tinywad::lump::{LumpAdd, LumpAddKind};	/	tilde.team	70
iuse tinywad::models::operation::WadOp;	/	tilde.team	70
iuse tinywad::wad::{Wad, WadKind,};	/	tilde.team	70
i	/	tilde.team	70
ifn main() -> Result<(), WadError> {	/	tilde.team	70
i    let mut src = Wad::new();	/	tilde.team	70
i	/	tilde.team	70
i    let lump_names = [	/	tilde.team	70
i        "FLOOR0_1", "FLOOR0_3", "FLOOR0_6",	/	tilde.team	70
i        "FLOOR1_1", "FLOOR1_7", "FLOOR3_3",	/	tilde.team	70
i        "FLOOR4_1", "FLOOR4_5", "FLOOR4_6",	/	tilde.team	70
i        "FLOOR4_8", "FLOOR5_1", "FLOOR5_2",	/	tilde.team	70
i        "FLOOR5_3", "FLOOR5_4", "FLOOR6_1",	/	tilde.team	70
i        "FLOOR6_2", "FLOOR7_1", "FLOOR7_2",	/	tilde.team	70
i    ];	/	tilde.team	70
i	/	tilde.team	70
i    src.load_from_file("doom.wad")?;	/	tilde.team	70
i	/	tilde.team	70
i    let gate = src.lump("FLOOR6_1").unwrap();	/	tilde.team	70
i	/	tilde.team	70
i    let mut dest = Wad::new();	/	tilde.team	70
i	/	tilde.team	70
i    dest.set_kind(WadKind::Pwad);	/	tilde.team	70
i    dest.add_lump_raw(	/	tilde.team	70
i        LumpAdd::new(	/	tilde.team	70
i            LumpAddKind::Back,	/	tilde.team	70
i            &vec![],	/	tilde.team	70
i            "FF_START",	/	tilde.team	70
i        )	/	tilde.team	70
i    )?;	/	tilde.team	70
i	/	tilde.team	70
i    for lump_name in lump_names {	/	tilde.team	70
i        dest.add_lump_raw(	/	tilde.team	70
i            LumpAdd::new(	/	tilde.team	70
i                LumpAddKind::Back,	/	tilde.team	70
i                &gate.data().buffer,	/	tilde.team	70
i                lump_name,	/	tilde.team	70
i            )	/	tilde.team	70
i        )?;	/	tilde.team	70
i    }	/	tilde.team	70
i	/	tilde.team	70
i    dest.add_lump_raw(	/	tilde.team	70
i        LumpAdd::new(	/	tilde.team	70
i            LumpAddKind::Back,	/	tilde.team	70
i            &vec![],	/	tilde.team	70
i            "F_END",	/	tilde.team	70
i        )	/	tilde.team	70
i    )?;	/	tilde.team	70
i	/	tilde.team	70
i    dest.save("doom1_patch.wad");	/	tilde.team	70
i	/	tilde.team	70
i    Ok(())	/	tilde.team	70
i}	/	tilde.team	70
i	/	tilde.team	70
iTo take the screenshot (below) doom1_patch.wad has been	/	tilde.team	70
iinjected into GZDOOM with the IWAD doom.wad (registered).	/	tilde.team	70
