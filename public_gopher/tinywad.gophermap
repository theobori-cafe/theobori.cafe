i### Extracting MIDI lumps	/	tilde.team	70
i	/	tilde.team	70
iExtracting every musics from the IWAD doom.wad.	/	tilde.team	70
i	/	tilde.team	70
iuse tinywad::error::WadError;	/	tilde.team	70
iuse tinywad::models::operation::WadOp;	/	tilde.team	70
iuse tinywad::wad::{Wad};	/	tilde.team	70
i	/	tilde.team	70
ifn main() -> Result<(), WadError> {	/	tilde.team	70
i    let mut src = Wad::new();	/	tilde.team	70
i	/	tilde.team	70
i    src.load_from_file("doom.wad")?;	/	tilde.team	70
i    src.select("D_");	/	tilde.team	70
i    src.save_lumps(".");	/	tilde.team	70
i	/	tilde.team	70
i    Ok(())	/	tilde.team	70
i}	/	tilde.team	70
i	/	tilde.team	70
