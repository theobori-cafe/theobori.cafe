i## title: DOOM modding library	/	tilde.team	70
i## date: "2023-05-03"	/	tilde.team	70
i	/	tilde.team	70
iThis project is a WAD library/manager, it can be used as a	/	tilde.team	70
ibase for other WAD projects like a GUI, a CLI, etc..	/	tilde.team	70
i	/	tilde.team	70
iI have played around with some well known IWAD like doom.wad	/	tilde.team	70
iand doom2.wad (registered).	/	tilde.team	70
i	/	tilde.team	70
iTo test the IWAD/PWAD generated, I have used two engines:	/	tilde.team	70
i- GZDoom (tests + screenshots)	/	tilde.team	70
i- WAD Commander (tests + preview in multiple contexts)	/	tilde.team	70
hGZDoom	URL:https://zdoom.org/index	zdoom.org	443
hWAD Commander	URL:https://wadcmd.com/	wadcmd.com	443
i	/	tilde.team	70
i## Use cases	/	tilde.team	70
i	/	tilde.team	70
iSome use cases you could use in a DOOM modding context.	/	tilde.team	70
i	/	tilde.team	70
i### IWAD patching	/	tilde.team	70
i	/	tilde.team	70
iuse tinywad::error::WadError;	/	tilde.team	70
iuse tinywad::models::operation::WadOp;	/	tilde.team	70
iuse tinywad::wad::Wad;	/	tilde.team	70
i	/	tilde.team	70
ifn main() -> Result<(), WadError> {	/	tilde.team	70
i    let mut doom_2 = Wad::new();	/	tilde.team	70
i    doom_2.load_from_file("wads/doom2.wad")?;	/	tilde.team	70
i	/	tilde.team	70
i    let gate = doom_2.lump("GATE3").unwrap();	/	tilde.team	70
i	/	tilde.team	70
i    let mut doom_1 = Wad::new();	/	tilde.team	70
i    doom_1.load_from_file("doom1.wad")?;	/	tilde.team	70
i	/	tilde.team	70
i    doom_1.select("^FLAT|FLOOR");	/	tilde.team	70
i    doom_1.update_lumps_raw(&gate.data().buffer);	/	tilde.team	70
i    doom_1.save("doom1.wad");	/	tilde.team	70
i	/	tilde.team	70
i    Ok(())	/	tilde.team	70
i}	/	tilde.team	70
i	/	tilde.team	70
iSo basically (above) it loads a first IWAD file, in our case	/	tilde.team	70
iit is doom2.wad. It borrows a lump (GATE3) into the variable	/	tilde.team	70
igate, then we load a second IWAD which is doom1.wad, it	/	tilde.team	70
iselects desired lumps, then it update the selected lumps in	/	tilde.team	70
iDOOM1 and finally overwrite the file.	/	tilde.team	70
i	/	tilde.team	70
i### Screenhot(s)	/	tilde.team	70
i/doom_gate3.png	/	tilde.team	70
I/doom_gate3.png	/~nagi/doom_gate3.png	tilde.team	70
i	/	tilde.team	70
i### Lumps extracting	/	tilde.team	70
i	/	tilde.team	70
iuse std::fs;	/	tilde.team	70
i	/	tilde.team	70
iuse tinywad::dir::MAX_PAL;	/	tilde.team	70
iuse tinywad::error::WadError;	/	tilde.team	70
iuse tinywad::models::operation::WadOp;	/	tilde.team	70
iuse tinywad::wad::Wad;	/	tilde.team	70
i	/	tilde.team	70
ifn main() -> Result<(), WadError> {	/	tilde.team	70
i    let mut doom_2 = Wad::new();	/	tilde.team	70
i    doom_2.load_from_file("wads/doom2.wad")?;	/	tilde.team	70
i	/	tilde.team	70
i    for pal in 0..MAX_PAL {	/	tilde.team	70
i        doom_2.set_palette(pal);	/	tilde.team	70
i        doom_2.reload()?;	/	tilde.team	70
i        doom_2.select("^BOSF");	/	tilde.team	70
i	/	tilde.team	70
i        let dirpath = format!("doom2/pal_{}", pal);	/	tilde.team	70
i	/	tilde.team	70
i        fs::create_dir_all(dirpath.clone()).unwrap();	/	tilde.team	70
i	/	tilde.team	70
i        doom_2.save_lumps(dirpath);	/	tilde.team	70
i    }	/	tilde.team	70
i	/	tilde.team	70
i    Ok(())	/	tilde.team	70
i}	/	tilde.team	70
i	/	tilde.team	70
iIn this part of code, it extracts as PNG the selected lumps	/	tilde.team	70
iwith different palettes (13).	/	tilde.team	70
i	/	tilde.team	70
