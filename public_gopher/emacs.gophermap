i	/	tilde.team	70
iHere's what the file structure looks like.	/	tilde.team	70
imodules/home/editors/emacs	/	tilde.team	70
i├── default.nix	/	tilde.team	70
i└── packages	/	tilde.team	70
i    ├── auto-save	/	tilde.team	70
i    │   └── default.nix	/	tilde.team	70
i    ├── dashboard	/	tilde.team	70
i    │   └── default.nix	/	tilde.team	70
i    ├── dired	/	tilde.team	70
i    │   └── default.nix	/	tilde.team	70
i    ├── doom-modeline	/	tilde.team	70
i    │   └── default.nix	/	tilde.team	70
i    ├── ivy	/	tilde.team	70
i    │   └── default.nix	/	tilde.team	70
i    ├── lsp-mode	/	tilde.team	70
i    │   ├── bash-language-server	/	tilde.team	70
i    │   │   └── default.nix	/	tilde.team	70
i    │   ├── default.nix	/	tilde.team	70
i    │   ├── dockerfile	/	tilde.team	70
i    │   │   └── default.nix	/	tilde.team	70
i    │   ├── gopls	/	tilde.team	70
i    │   │   └── default.nix	/	tilde.team	70
i...	/	tilde.team	70
i	/	tilde.team	70
iThese modules contain the dependencies, i.e. the Emacs	/	tilde.team	70
ipackages and the Emacs Lisp configuration.	/	tilde.team	70
hEmacs	URL:https://www.gnu.org/s/emacs/	www.gnu.org	443
hEmacs	URL:https://www.gnu.org/s/emacs/	www.gnu.org	443
i	/	tilde.team	70
iHere's an example with the org-superstar package.	/	tilde.team	70
horg-superstar	URL:https://github.com/integral-dw/org-superstar-mode	github.com	443
i	/	tilde.team	70
i{	/	tilde.team	70
i  config,	/	tilde.team	70
i  lib,	/	tilde.team	70
i  namespace,	/	tilde.team	70
i  ...	/	tilde.team	70
i}:	/	tilde.team	70
ilet	/	tilde.team	70
i  inherit (lib) mkIf;	/	tilde.team	70
i  inherit (lib.${namespace}) mkBoolOpt;	/	tilde.team	70
i	/	tilde.team	70
i  cfg = config.${namespace}.editors.emacs.packages.org-	/	tilde.team	70
isuperstar;	/	tilde.team	70
iin	/	tilde.team	70
i{	/	tilde.team	70
i  options.${namespace}.editors.emacs.packages.org-superstar =	/	tilde.team	70
i{	/	tilde.team	70
i    enable = mkBoolOpt false "Whether or not to enable the	/	tilde.team	70
iemacs org-superstar package.";	/	tilde.team	70
i  };	/	tilde.team	70
i	/	tilde.team	70
i  config = mkIf cfg.enable {	/	tilde.team	70
i    programs.emacs = {	/	tilde.team	70
i      extraPackages = (epkgs: [ epkgs.org-superstar ]);	/	tilde.team	70
i      extraConfig = ''	/	tilde.team	70
i        (use-package org-superstar	/	tilde.team	70
i          :ensure t	/	tilde.team	70
i          :after org	/	tilde.team	70
i          :hook (org-mode . org-superstar-mode)	/	tilde.team	70
i          :custom	/	tilde.team	70
i            (org-superstar-remove-leading-stars t)	/	tilde.team	70
i            (org-superstar-headline-bullets-list '("⁖" "✿" "▷"	/	tilde.team	70
i"✸")))	/	tilde.team	70
i      '';	/	tilde.team	70
i    };	/	tilde.team	70
i  };	/	tilde.team	70
i}	/	tilde.team	70
